{
  "$schema": "design-system/v1",
  "$project": "NOME_DO_PROJETO",
  "$generated": "YYYY-MM-DD",
  "$reference": "URL_OU_DESCRICAO_DA_REFERENCIA",

  "colors": {
    "primary": {
      "default": "#______",
      "dark": "#______",
      "light": "#______",
      "foreground": "#______"
    },
    "secondary": {
      "default": "#______",
      "dark": "#______",
      "light": "#______",
      "foreground": "#______"
    },
    "background": {
      "default": "#______",
      "subtle": "#______",
      "muted": "#______"
    },
    "surface": {
      "default": "#______",
      "raised": "#______",
      "overlay": "#______"
    },
    "text": {
      "primary": "#______",
      "secondary": "#______",
      "tertiary": "#______",
      "disabled": "#______",
      "inverse": "#______"
    },
    "border": {
      "default": "#______",
      "subtle": "#______",
      "strong": "#______"
    },
    "semantic": {
      "success": "#______",
      "successLight": "#______",
      "warning": "#______",
      "warningLight": "#______",
      "error": "#______",
      "errorLight": "#______",
      "info": "#______",
      "infoLight": "#______"
    }
  },

  "typography": {
    "fontFamily": {
      "primary": "'NOME_DA_FONTE', sans-serif",
      "secondary": "null",
      "mono": "'FONTE_MONO', monospace"
    },
    "scale": {
      "display": { "size": "00px", "weight": 000, "lineHeight": "1.0", "letterSpacing": "-0.02em" },
      "h1":      { "size": "00px", "weight": 000, "lineHeight": "1.1", "letterSpacing": "-0.01em" },
      "h2":      { "size": "00px", "weight": 000, "lineHeight": "1.2", "letterSpacing": "-0.01em" },
      "h3":      { "size": "00px", "weight": 000, "lineHeight": "1.3", "letterSpacing": "0" },
      "h4":      { "size": "00px", "weight": 000, "lineHeight": "1.4", "letterSpacing": "0" },
      "bodyLg":  { "size": "00px", "weight": 000, "lineHeight": "1.6", "letterSpacing": "0" },
      "body":    { "size": "00px", "weight": 000, "lineHeight": "1.6", "letterSpacing": "0" },
      "bodySm":  { "size": "00px", "weight": 000, "lineHeight": "1.5", "letterSpacing": "0" },
      "caption": { "size": "00px", "weight": 000, "lineHeight": "1.4", "letterSpacing": "0.01em" },
      "label":   { "size": "00px", "weight": 000, "lineHeight": "1.0", "letterSpacing": "0.05em" }
    }
  },

  "spacing": {
    "base": 4,
    "scale": {
      "xs":  "4px",
      "sm":  "8px",
      "md":  "16px",
      "lg":  "24px",
      "xl":  "32px",
      "2xl": "48px",
      "3xl": "64px",
      "4xl": "96px",
      "5xl": "128px"
    },
    "layout": {
      "containerMaxWidth": "0000px",
      "containerPadding": "00px",
      "sectionPadding": "00px",
      "columnGutter": "00px"
    }
  },

  "borders": {
    "radius": {
      "none":   "0px",
      "sm":     "0px",
      "md":     "0px",
      "lg":     "0px",
      "xl":     "0px",
      "full":   "9999px"
    },
    "width": {
      "thin":   "1px",
      "medium": "2px",
      "thick":  "3px"
    },
    "style": "SHARP | ROUNDED | PILL"
  },

  "shadows": {
    "none": "none",
    "low":  "0 1px 3px rgba(0,0,0,0.00), 0 1px 2px rgba(0,0,0,0.00)",
    "mid":  "0 4px 6px rgba(0,0,0,0.00), 0 2px 4px rgba(0,0,0,0.00)",
    "high": "0 10px 25px rgba(0,0,0,0.00), 0 5px 10px rgba(0,0,0,0.00)",
    "glow": "0 0 20px rgba(0,0,0,0.00)"
  },

  "animation": {
    "duration": {
      "instant": "50ms",
      "fast":    "150ms",
      "normal":  "250ms",
      "slow":    "400ms",
      "slower":  "600ms"
    },
    "easing": {
      "default":   "cubic-bezier(0.4, 0, 0.2, 1)",
      "in":        "cubic-bezier(0.4, 0, 1, 1)",
      "out":       "cubic-bezier(0, 0, 0.2, 1)",
      "bounce":    "cubic-bezier(0.34, 1.56, 0.64, 1)"
    },
    "style": "SUBTLE | EXPRESSIVE | NONE"
  },

  "imagery": {
    "style":    "FOTO_REAL | ILUSTRACAO_FLAT | ILUSTRACAO_3D | ABSTRATO | MISTO",
    "tone":     "CLARO | ESCURO | COLORIDO | MONOCROMATICO",
    "source":   "AI_GENERATED | UNSPLASH | PEXELS | ASSETS_PROPRIOS",
    "ratio":    "16:9 | 4:3 | 1:1 | 3:4",
    "hasMockups": false,
    "notes":    "Descrever estilo visual em detalhes aqui"
  },

  "components": {
    "button": {
      "primary":   { "bg": "colors.primary.default", "text": "colors.primary.foreground", "radius": "borders.radius.md" },
      "secondary": { "bg": "transparent", "border": "colors.border.default", "radius": "borders.radius.md" },
      "ghost":     { "bg": "transparent", "text": "colors.primary.default", "radius": "borders.radius.md" }
    },
    "card": {
      "bg":      "colors.surface.default",
      "border":  "colors.border.subtle",
      "radius":  "borders.radius.lg",
      "shadow":  "shadows.low",
      "padding": "spacing.scale.lg"
    },
    "input": {
      "bg":          "colors.surface.default",
      "border":      "colors.border.default",
      "borderFocus": "colors.primary.default",
      "radius":      "borders.radius.md",
      "padding":     "spacing.scale.md"
    }
  },

  "antiPatterns": [
    "Gradiente roxo genérico sem justificativa",
    "Fonte Inter como única opção sem avaliação",
    "Layout apenas com ícones sem imagens reais",
    "Fundo branco puro #FFFFFF em grandes áreas",
    "ADICIONAR_ANTI_PADRAO_ESPECIFICO_DO_PROJETO"
  ],

  "notes": "Observações adicionais sobre este design system específico"
}
